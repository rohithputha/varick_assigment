{
  "version": "1.0",
  "updated_at": "2026-03-11T00:00:00",
  "rules": [
    {
      "id": "rule1_physical_goods",
      "priority": 10,
      "description": "Physical goods always go to Office Supplies, overrides dept",
      "condition": {
        "category_hint": { "eq": "physical_goods" }
      },
      "output": {
        "gl_account": "5000",
        "treatment": "EXPENSE",
        "confidence": 1.0
      },
      "enabled": true
    },
    {
      "id": "rule2_equipment_capitalize",
      "priority": 20,
      "description": "Equipment unit cost >= $5K → capitalize as fixed asset",
      "condition": {
        "category_hint": { "eq": "equipment" },
        "unit_cost": { "gte": 5000 }
      },
      "output": {
        "gl_account": "1500",
        "treatment": "CAPITALIZE",
        "confidence": 0.95
      },
      "enabled": true
    },
    {
      "id": "rule2_equipment_expense",
      "priority": 21,
      "description": "Equipment unit cost < $5K → expense directly",
      "condition": {
        "category_hint": { "eq": "equipment" },
        "unit_cost": { "lt": 5000 }
      },
      "output": {
        "gl_account": "5110",
        "treatment": "EXPENSE",
        "confidence": 0.95
      },
      "enabled": true
    },
    {
      "id": "rule2_equipment_fallback",
      "priority": 22,
      "description": "Equipment, unit_cost unknown — use line_amount as proxy (lower confidence)",
      "condition": {
        "category_hint": { "eq": "equipment" },
        "unit_cost": { "is_null": true },
        "line_amount": { "gte": 5000 }
      },
      "output": {
        "gl_account": "1500",
        "treatment": "CAPITALIZE",
        "confidence": 0.85
      },
      "enabled": true
    },
    {
      "id": "rule3_software_prepaid",
